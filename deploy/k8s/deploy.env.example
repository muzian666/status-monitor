# K8s deploy environment config
# Copy this file to deploy.env and fill in your values

# Container registry address
REGISTRY=your-registry:5000

# Image name and tag
IMAGE_NAME=status-monitor
IMAGE_TAG=latest

# Target node hostname (for local PV affinity)
NODE_HOSTNAME=your-node-hostname

# Local data path on the node
LOCAL_DATA_PATH=/data/status-monitor
